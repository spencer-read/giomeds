# -----------------------------------------------------------------------
# GioMeds — Environment Variable Template
# Copy this file to .env and fill in real values for local development.
# On Railway, set these directly in the environment variables dashboard.
# NEVER commit a populated .env file to version control.
# -----------------------------------------------------------------------

# --- Twilio ---
# Your Twilio Account SID (starts with AC...)
TWILIO_ACCOUNT_SID=

# Your Twilio Auth Token
TWILIO_AUTH_TOKEN=

# The Twilio phone number that sends and receives SMS (E.164 format)
TWILIO_PHONE_NUMBER=+1XXXXXXXXXX

# --- Users ---
# Spencer's phone number (E.164 format, e.g. +14155550001)
SPENCER_PHONE=+1XXXXXXXXXX

# Peter's phone number (E.164 format, e.g. +14155550002)
PETER_PHONE=+1XXXXXXXXXX

# --- Google Sheets ---
# Full JSON contents of the service account key file, as a single-line string.
# Paste the entire contents of your downloaded service-account JSON here,
# collapsed onto one line (no newlines inside the value).
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN RSA PRIVATE KEY-----\\n...\\n-----END RSA PRIVATE KEY-----\\n","client_email":"giomeds@your-project.iam.gserviceaccount.com","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token","auth_provider_x509_cert_url":"https://www.googleapis.com/oauth2/v1/certs","client_x509_cert_url":"..."}

# The Sheet ID from the Google Sheets URL:
# https://docs.google.com/spreadsheets/d/SHEET_ID_HERE/edit
GOOGLE_SHEET_ID=

# --- Admin UI ---
# Password to log in to the /admin interface
ADMIN_PASSWORD=

# Flask session secret key — set to a long random string (e.g. output of: python -c "import secrets; print(secrets.token_hex(32))")
ADMIN_SECRET_KEY=

# --- Timezone ---
# IANA timezone string for scheduling and display
# See: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TIMEZONE=Europe/London
